# Backend environment variables for Terminas
# (reconstructed from source — the repo shipped without an example file)
# Copy this file to `.env` and fill in real values.

# MongoDB connection string (mongoose). Local example shown; use your Atlas URI if remote.
CONNECTION_STR=mongodb://localhost:27017/terminas

# Secret used to sign JWT auth tokens. Use any long random string.
JWT_SECRET=change_me_to_a_long_random_secret

# Gmail App Password for the OTP/password-reset mailer (sender is hardcoded in util/nodemailer.js).
# Leave blank to run without working email/OTP.
NODEMAILER_PASS=

# Base URL advertised in the Swagger API docs (backend/swagger.js).
DEPLOY_URL=http://localhost:3000

# Note: Redis host/port are hardcoded to localhost:6380 in backend/redis-server.js (not read from env).
