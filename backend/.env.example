# Backend environment variables for Terminas
# Copy this file to `.env` and fill in real values.

# MongoDB connection string (mongoose).
# Local:  mongodb://localhost:27017/terminas
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/terminas
CONNECTION_STR=mongodb://localhost:27017/terminas

# Secret used to sign JWT auth tokens. Use any long random string.
JWT_SECRET=change_me_to_a_long_random_secret

# Gmail App Password for the OTP/password-reset mailer (sender hardcoded in util/nodemailer.js).
# Leave blank to run without working email/OTP.
NODEMAILER_PASS=

# Base URL advertised in the Swagger API docs (backend/swagger.js).
DEPLOY_URL=http://localhost:3000

# Port the server binds to. Render injects PORT automatically; locally defaults to 3000.
# PORT=3000

# Redis: provide EITHER a full URL (preferred on Render Key Value) ...
# REDIS_URL=redis://default:password@host:6379
# ... OR host/port (defaults to the local redis-stack container on 6380).
# REDIS_HOST=localhost
# REDIS_PORT=6380
