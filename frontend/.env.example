# Frontend environment variables (Vite)
# Copy to `.env` for local dev. In production set these in your host's
# build environment (e.g. Render static site dashboard).

# Backend API base URL.
VITE_API_URL=http://localhost:3000

# Base host (scheme + host, NO port) where per-user dev containers are reachable.
# Local: http://localhost. Docker-host deploy: that host's public address,
# e.g. http://203.0.113.10
VITE_CONTAINER_HOST=http://localhost
